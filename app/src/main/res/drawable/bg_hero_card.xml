<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/md3_primary_container" />
            <corners
                android:topLeftRadius="@dimen/corner_hero"
                android:topRightRadius="@dimen/corner_hero_sm"
                android:bottomLeftRadius="@dimen/corner_hero_sm"
                android:bottomRightRadius="@dimen/corner_hero" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="@android:color/transparent"
                android:endColor="@color/md3_surface_bright"
                android:angle="135" />
            <corners
                android:topLeftRadius="@dimen/corner_hero"
                android:topRightRadius="@dimen/corner_hero_sm"
                android:bottomLeftRadius="@dimen/corner_hero_sm"
                android:bottomRightRadius="@dimen/corner_hero" />
        </shape>
    </item>
</layer-list>
