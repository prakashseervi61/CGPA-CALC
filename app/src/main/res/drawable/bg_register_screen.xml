<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/md3_background" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="@color/register_glow_a"
                android:endColor="@android:color/transparent"
                android:type="radial"
                android:gradientRadius="150%p"
                android:centerX="0%"
                android:centerY="0%" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="@color/register_glow_b"
                android:endColor="@android:color/transparent"
                android:type="radial"
                android:gradientRadius="150%p"
                android:centerX="100%"
                android:centerY="100%" />
        </shape>
    </item>
</layer-list>
