<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/bg_register_screen">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingTop="@dimen/spacing_md"
        android:paddingBottom="32dp"
        android:animateLayoutChanges="true">

        <!-- Back Button -->
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/content_desc_back"
            android:src="@drawable/ic_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Logo -->
        <ImageView
            android:id="@+id/ivLogo"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginTop="4dp"
            android:contentDescription="@string/content_desc_logo"
            android:src="@drawable/ic_school_rounded"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnBack" />

        <!-- Title -->
        <TextView
            android:id="@+id/tvTitle"
            style="@style/TextAppearance.Semora.Title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center_horizontal"
            android:text="@string/title_login"
            android:textColor="@color/md3_on_surface"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ivLogo" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/tvSubtitle"
            style="@style/TextAppearance.Semora.Subtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_horizontal"
            android:text="@string/login_subtitle"
            android:textColor="@color/md3_on_surface_variant"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvTitle" />

        <!-- Username Field -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilUsername"
            style="@style/Widget.Material3.TextInputLayout.FilledBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:hint="@string/username_label"
            app:boxBackgroundColor="@color/md3_surface_container_low"
            app:boxCornerRadiusBottomEnd="@dimen/corner_large"
            app:boxCornerRadiusBottomStart="@dimen/corner_large"
            app:boxCornerRadiusTopEnd="@dimen/corner_large"
            app:boxCornerRadiusTopStart="@dimen/corner_large"
            app:boxStrokeWidth="0dp"
            app:boxStrokeWidthFocused="0dp"
            app:endIconMode="clear_text"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
            app:startIconDrawable="@drawable/ic_person"
            app:startIconTint="@color/md3_on_surface_variant">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etUsername"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:inputType="textPersonName"
                android:maxLength="32"
                android:gravity="top|start" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Username Error -->
        <TextView
            android:id="@+id/tvUsernameError"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:paddingStart="4dp"
            android:textColor="@color/md3_error"
            android:textSize="12sp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tilUsername"
            tools:text="Username cannot be empty"
            tools:visibility="visible" />

        <!-- PIN Label -->
        <TextView
            android:id="@+id/tvPinLabel"
            style="@style/TextAppearance.Semora.FieldLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:text="@string/pin_label"
            android:textColor="@color/md3_on_surface"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvUsernameError"
            app:layout_goneMarginTop="@dimen/spacing_lg" />

        <!-- PIN Container -->
        <LinearLayout
            android:id="@+id/pinContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvPinLabel">

            <EditText
                android:id="@+id/etPin1"
                style="@style/PinEditTextStyle"
                android:contentDescription="@string/content_desc_pin_digit"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:inputType="number"
                android:maxLength="1" />

            <Space
                android:layout_width="8dp"
                android:layout_height="24dp" />

            <EditText
                android:id="@+id/etPin2"
                style="@style/PinEditTextStyle"
                android:contentDescription="@string/content_desc_pin_digit"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:inputType="number"
                android:maxLength="1" />

            <Space
                android:layout_width="8dp"
                android:layout_height="24dp" />

            <EditText
                android:id="@+id/etPin3"
                style="@style/PinEditTextStyle"
                android:contentDescription="@string/content_desc_pin_digit"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:inputType="number"
                android:maxLength="1" />

            <Space
                android:layout_width="8dp"
                android:layout_height="24dp" />

            <EditText
                android:id="@+id/etPin4"
                style="@style/PinEditTextStyle"
                android:contentDescription="@string/content_desc_pin_digit"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:inputType="number"
                android:maxLength="1" />

        </LinearLayout>

        <!-- PIN Error -->
        <TextView
            android:id="@+id/tvPinError"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:paddingStart="4dp"
            android:textColor="@color/md3_error"
            android:textSize="12sp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/pinContainer"
            tools:text="PIN must be exactly 4 digits"
            tools:visibility="visible" />

        <!-- Login Button -->
        <FrameLayout
            android:id="@+id/flButtonContainer"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="@dimen/spacing_lg"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvPinError">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                style="@style/TextAppearance.Semora.Button"
                android:text="@string/button_sign_in"
                android:textAllCaps="false"
                android:textColor="@color/md3_on_primary"
                app:backgroundTint="@color/md3_primary"
                app:shapeAppearance="@style/ShapeAppearance.Semora.HeroCard"
                app:icon="@drawable/ic_arrow_forward"
                app:iconGravity="textEnd"
                app:iconSize="20dp"
                app:iconTint="@color/md3_on_primary" />

            <ProgressBar
                android:id="@+id/btnProgress"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:indeterminateTint="@color/md3_primary"
                android:visibility="gone" />

        </FrameLayout>

        <!-- Sign Up Link -->
        <LinearLayout
            android:id="@+id/llSignUp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:gravity="center"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/flButtonContainer">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/login_help_text"
                android:textColor="@color/md3_on_surface_variant"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvSignUp"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="@string/register_btn"
                android:textColor="@color/md3_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>