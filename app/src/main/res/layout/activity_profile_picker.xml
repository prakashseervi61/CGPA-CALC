<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pp_surface"
    android:clipChildren="false"
    android:clipToPadding="false"
    tools:context="com.prakash.semora.ui.auth.ProfilePickerActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:clipChildren="false">

        <!-- ==================== Hero Section ==================== -->
        <FrameLayout
            android:id="@+id/heroSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_gradient_primary"
            android:paddingTop="24dp"
            android:paddingBottom="0dp"
            android:gravity="center"
            android:clipChildren="false"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingHorizontal="24dp">

                <!-- Logo glassmorphism circle -->
                <FrameLayout
                    android:id="@+id/ivLogoContainer"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:background="@drawable/bg_logo_circle"
                    android:elevation="2dp">

                    <ImageView
                        android:id="@+id/ivLogo"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_school_rounded"
                        android:contentDescription="@string/content_desc_logo"
                        android:tint="@android:color/white" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textAppearance="@style/TextAppearance.Semora.PoppinsBold"
                    android:textColor="@android:color/white"
                    android:layout_marginTop="12dp" />

                <TextView
                    android:id="@+id/tvTagline"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/pp_tagline"
                    android:textAppearance="@style/TextAppearance.Semora.NunitoMedium"
                    android:textColor="@android:color/white"
                    android:alpha="0.9"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:id="@+id/tvSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/pp_subtitle"
                    android:textAppearance="@style/TextAppearance.Semora.NunitoRegular"
                    android:textColor="@android:color/white"
                    android:alpha="0.8"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:maxLines="2" />
            </LinearLayout>
        </FrameLayout>

        <!-- ==================== Empty State ==================== -->
        <LinearLayout
            android:id="@+id/emptyState"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="24dp"
            android:clipChildren="false"
            android:visibility="visible"
            tools:visibility="visible">

            <!-- Empty state card (overlaps hero) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-16dp"
                app:cardCornerRadius="@dimen/corner_28"
                app:cardElevation="8dp"
                app:cardBackgroundColor="@color/pp_card_bg"
                app:strokeWidth="0dp"
                app:contentPadding="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">

                    <!-- Illustration -->
                    <ImageView
                        android:id="@+id/ivEmptyIllustration"
                        android:layout_width="100dp"
                        android:layout_height="80dp"
                        android:src="@drawable/pp_hero_illustration"
                        android:importantForAccessibility="no" />

                    <TextView
                        android:id="@+id/tvEmptyTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/pp_empty_title"
                        android:textAppearance="@style/TextAppearance.Semora.PoppinsSemiBold"
                        android:textColor="@color/pp_on_surface"
                        android:layout_marginTop="20dp" />

                    <TextView
                        android:id="@+id/tvEmptyDesc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/pp_empty_desc"
                        android:textAppearance="@style/TextAppearance.Semora.NunitoRegular"
                        android:textColor="@color/pp_on_surface_variant"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:lineSpacingExtra="4sp" />

                    <!-- Primary gradient button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCreateFirst"
                        style="@style/Widget.Semora.Button.Gradient"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="20dp"
                        android:text="@string/pp_btn_create_first"
                        android:background="@drawable/bg_btn_gradient"
                        android:stateListAnimator="@null"
                        app:icon="@drawable/ic_add"
                        app:iconGravity="textStart"
                        app:iconTint="@android:color/white"
                        app:cornerRadius="@dimen/corner_28" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ==================== Feature Cards Grid ==================== -->
            <androidx.gridlayout.widget.GridLayout
                android:id="@+id/featureGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2"
                android:alignmentMode="alignBounds"
                android:columnOrderPreserved="false"
                android:layout_marginTop="24dp"
                android:paddingBottom="4dp">

                <!-- Feature Card 1: Track Semesters -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardFeatureSemester"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_columnWeight="1"
                    android:layout_rowWeight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/pp_feature_semester_bg"
                    app:strokeWidth="0dp"
                    app:contentPadding="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/pp_ic_feature_semester"
                            android:importantForAccessibility="no" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/pp_feature_semester_title"
                            android:textAppearance="@style/TextAppearance.Semora.NunitoCaption"
                            android:textColor="@color/pp_on_surface"
                            android:textStyle="bold"
                            android:layout_marginTop="6dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/pp_feature_semester_desc"
                            android:textAppearance="@style/TextAppearance.Semora.NunitoCaption"
                            android:textColor="@color/pp_on_surface_variant"
                            android:maxLines="1"
                            android:textSize="10sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Feature Card 2: Calculate CGPA -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardFeatureCgpa"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_columnWeight="1"
                    android:layout_rowWeight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/pp_feature_cgpa_bg"
                    app:strokeWidth="0dp"
                    app:contentPadding="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/pp_ic_feature_cgpa"
                            android:importantForAccessibility="no" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/pp_feature_cgpa_title"
                            android:textAppearance="@style/TextAppearance.Semora.NunitoCaption"
                            android:textColor="@color/pp_on_surface"
                            android:textStyle="bold"
                            android:layout_marginTop="6dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/pp_feature_cgpa_desc"
                            android:textAppearance="@style/TextAppearance.Semora.NunitoCaption"
                            android:textColor="@color/pp_on_surface_variant"
                            android:maxLines="1"
                            android:textSize="10sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Feature Card 3: Monitor Progress -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardFeatureProgress"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_columnWeight="1"
                    android:layout_gravity="center_horizontal"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/pp_feature_progress_bg"
                    app:strokeWidth="0dp"
                    app:contentPadding="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/pp_ic_feature_progress"
                            android:importantForAccessibility="no"
                            android:layout_marginEnd="10dp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/pp_feature_progress_title"
                                android:textAppearance="@style/TextAppearance.Semora.NunitoCaption"
                                android:textColor="@color/pp_on_surface"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/pp_feature_progress_desc"
                                android:textAppearance="@style/TextAppearance.Semora.NunitoCaption"
                                android:textColor="@color/pp_on_surface_variant"
                                android:maxLines="1"
                                android:textSize="10sp"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </androidx.gridlayout.widget.GridLayout>

            <!-- Footer -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="bottom|center"
                android:paddingVertical="12dp">

                <TextView
                    android:id="@+id/tvFooter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/pp_footer"
                    android:textAppearance="@style/TextAppearance.Semora.NunitoCaption"
                    android:textColor="@color/pp_on_surface_variant" />

                <TextView
                    android:id="@+id/tvVersion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/pp_version"
                    android:textAppearance="@style/TextAppearance.Semora.NunitoCaption"
                    android:textColor="@color/pp_on_surface_variant"
                    android:alpha="0.7"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- ==================== Profile List Section ==================== -->
        <LinearLayout
            android:id="@+id/profileSection"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="gone">

            <TextView
                android:id="@+id/tvProfileSectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/pp_select_profile"
                android:textAppearance="@style/TextAppearance.Semora.PoppinsSemiBold"
                android:textColor="@color/pp_on_surface"
                android:layout_marginTop="24dp"
                android:layout_marginStart="24dp"
                android:layout_marginBottom="8dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvProfiles"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:paddingHorizontal="24dp"
                android:clipToPadding="false"
                android:paddingBottom="72dp"
                tools:listitem="@layout/item_profile" />
        </LinearLayout>
    </LinearLayout>

    <!-- ==================== Create New Profile FAB (visible when profiles exist) ==================== -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCreateNewFab"
        style="@style/Widget.Semora.Button.Gradient"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_margin="24dp"
        android:layout_gravity="bottom"
        android:text="@string/pp_create_new"
        android:background="@drawable/bg_btn_gradient"
        android:visibility="gone"
        app:icon="@drawable/ic_add"
        app:iconGravity="textStart"
        app:iconTint="@android:color/white"
        app:cornerRadius="@dimen/corner_28"
        tools:visibility="visible" />
</androidx.coordinatorlayout.widget.CoordinatorLayout>
