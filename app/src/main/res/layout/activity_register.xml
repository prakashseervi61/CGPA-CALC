<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/bg_register_screen"
    android:theme="@style/Theme.Semora"
    android:transitionName="fadeContainer">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingTop="@dimen/spacing_md"
        android:paddingBottom="32dp"
        android:animateLayoutChanges="true"
        android:clipChildren="false"
        android:clipToPadding="false">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/content_desc_back"
            android:src="@drawable/ic_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/ivLogo"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginTop="4dp"
            android:alpha="1.0"
            android:contentDescription="@string/content_desc_logo"
            android:src="@drawable/ic_semora_logo"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnBack" />

        <TextView
            android:id="@+id/tvTitle"
            style="@style/TextAppearance.Semora.Title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center_horizontal"
            android:text="@string/register_title"
            android:textColor="@color/md3_on_surface"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ivLogo" />

        <TextView
            android:id="@+id/tvSubtitle"
            style="@style/TextAppearance.Semora.Subtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_horizontal"
            android:text="@string/register_subtitle"
            android:textColor="@color/md3_on_surface_variant"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvTitle" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilUsername"
            style="@style/Widget.Material3.TextInputLayout.FilledBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:hint="@string/username_label"
            app:boxBackgroundColor="@color/md3_surface_container_low"
            app:boxCornerRadiusBottomEnd="@dimen/corner_large"
            app:boxCornerRadiusBottomStart="@dimen/corner_large"
            app:boxCornerRadiusTopEnd="@dimen/corner_large"
            app:boxCornerRadiusTopStart="@dimen/corner_large"
            app:boxStrokeWidth="0dp"
            app:boxStrokeWidthFocused="0dp"
            app:endIconMode="clear_text"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
            app:startIconDrawable="@drawable/ic_person"
            app:startIconTint="@color/md3_on_surface_variant">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etUsername"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:inputType="textPersonName"
                android:maxLength="32"
                android:gravity="top|start" />

        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/tvUsernameError"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:paddingStart="4dp"
            android:textColor="@color/md3_error"
            android:textSize="12sp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tilUsername"
            tools:text="Username is required"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/tvPinLabel"
            style="@style/TextAppearance.Semora.FieldLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:text="@string/pin_label"
            android:textColor="@color/md3_on_surface"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvUsernameError"
            app:layout_goneMarginTop="@dimen/spacing_lg" />

        <LinearLayout
            android:id="@+id/pinContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp"
            android:transitionName="pinErrorShake"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvPinLabel">

            <EditText
                android:id="@+id/etPin1"
                style="@style/PinEditTextStyle"
                android:contentDescription="@string/content_desc_pin_digit"
                tools:ignore="DuplicateSpeakableText" />

            <Space
                android:layout_width="12dp"
                android:layout_height="wrap_content" />

            <EditText
                android:id="@+id/etPin2"
                style="@style/PinEditTextStyle"
                android:contentDescription="@string/content_desc_pin_digit"
                tools:ignore="DuplicateSpeakableText" />

            <Space
                android:layout_width="12dp"
                android:layout_height="wrap_content" />

            <EditText
                android:id="@+id/etPin3"
                style="@style/PinEditTextStyle"
                android:contentDescription="@string/content_desc_pin_digit"
                tools:ignore="DuplicateSpeakableText" />

            <Space
                android:layout_width="12dp"
                android:layout_height="wrap_content" />

            <EditText
                android:id="@+id/etPin4"
                style="@style/PinEditTextStyle"
                android:contentDescription="@string/content_desc_pin_digit"
                tools:ignore="DuplicateSpeakableText" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvPinError"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:paddingStart="4dp"
            android:textColor="@color/md3_error"
            android:textSize="12sp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/pinContainer"
            tools:text="PIN must be exactly 4 digits"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/tvConfirmPinLabel"
            style="@style/TextAppearance.Semora.FieldLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:text="@string/confirm_pin_label"
            android:textColor="@color/md3_on_surface"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvPinError"
            app:layout_goneMarginTop="@dimen/spacing_md" />

        <LinearLayout
            android:id="@+id/confirmPinContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvConfirmPinLabel">

            <EditText
                android:id="@+id/etConfirmPin1"
                style="@style/PinEditTextStyle"
                android:contentDescription="@string/content_desc_confirm_pin_digit"
                tools:ignore="DuplicateSpeakableText" />

            <Space
                android:layout_width="12dp"
                android:layout_height="wrap_content" />

            <EditText
                android:id="@+id/etConfirmPin2"
                style="@style/PinEditTextStyle"
                android:contentDescription="@string/content_desc_confirm_pin_digit"
                tools:ignore="DuplicateSpeakableText" />

            <Space
                android:layout_width="12dp"
                android:layout_height="wrap_content" />

            <EditText
                android:id="@+id/etConfirmPin3"
                style="@style/PinEditTextStyle"
                android:contentDescription="@string/content_desc_confirm_pin_digit"
                tools:ignore="DuplicateSpeakableText" />

            <Space
                android:layout_width="12dp"
                android:layout_height="wrap_content" />

            <EditText
                android:id="@+id/etConfirmPin4"
                style="@style/PinEditTextStyle"
                android:contentDescription="@string/content_desc_confirm_pin_digit"
                tools:ignore="DuplicateSpeakableText" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvConfirmPinError"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:paddingStart="4dp"
            android:textColor="@color/md3_error"
            android:textSize="12sp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/confirmPinContainer"
            tools:text="PINs do not match"
            tools:visibility="visible" />

        <FrameLayout
            android:id="@+id/flButtonContainer"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="@dimen/spacing_lg"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvConfirmPinError"
            app:layout_goneMarginTop="@dimen/spacing_lg">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRegister"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                style="@style/TextAppearance.Semora.Button"
                android:text="@string/register_btn"
                android:textAllCaps="false"
                android:textColor="@color/md3_on_primary"
                app:backgroundTint="@color/md3_primary"
                app:shapeAppearance="@style/ShapeAppearance.Semora.HeroCard"
                app:icon="@drawable/ic_arrow_forward"
                app:iconGravity="textEnd"
                app:iconSize="20dp"
                app:iconTint="@color/md3_on_primary" />

            <ProgressBar
                android:id="@+id/btnProgress"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:indeterminateTint="@color/md3_primary"
                android:visibility="gone" />

        </FrameLayout>

        <LinearLayout
            android:id="@+id/llLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:gravity="center"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/flButtonContainer">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/register_have_account"
                android:textColor="@color/md3_on_surface_variant"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/btnBackToLogin"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="@string/register_login"
                android:textColor="@color/md3_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>
