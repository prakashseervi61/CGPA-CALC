<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md3_background">

    <!-- Top Bar -->
    <RelativeLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/md3_background"
        android:clipToPadding="false"
        android:paddingHorizontal="@dimen/spacing_lg"
        android:paddingTop="@dimen/spacing_md"
        android:paddingBottom="@dimen/spacing_xs"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivAvatar"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_person_rounded"
            android:tint="?attr/colorOnBackground" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_toEndOf="@id/ivAvatar"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvGreeting"
                style="@style/TextAppearance.Semora.Headline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="Good morning" />

            <TextView
                android:id="@+id/tvUsername"
                style="@style/TextAppearance.Semora.BodySmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="-2dp"
                android:textColor="@color/md3_on_surface_variant"
                tools:text="Alex" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true">

            <ImageButton
                android:id="@+id/btnNotifications"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_notification_button"
                android:contentDescription="Notifications"
                android:padding="10dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_notification" />

            <!-- Tiny notification dot badge -->
            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="6dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_nav_pill"
                android:backgroundTint="@color/md3_primary" />
        </FrameLayout>
    </RelativeLayout>



    <!-- Loading skeleton (shown while data loads) -->
    <LinearLayout
        android:id="@+id/loadingShimmer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/spacing_lg"
        android:paddingTop="@dimen/spacing_md"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <!-- Hero card skeleton -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="160dp"
            app:shapeAppearance="@style/ShapeAppearance.Semora.HeroCard"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/md3_surface_container"
            app:strokeWidth="0dp" />

        <!-- Stats row skeleton -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:orientation="horizontal"
            android:weightSum="2">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/spacing_xs"
                app:cardCornerRadius="@dimen/corner_large"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/md3_surface_container"
                app:strokeWidth="0dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/spacing_xs"
                app:cardCornerRadius="@dimen/corner_large"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/md3_surface_container"
                app:strokeWidth="0dp" />
        </LinearLayout>

        <!-- Section title skeleton -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="120dp"
            android:layout_height="16dp"
            android:layout_marginTop="@dimen/spacing_lg"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/md3_surface_container"
            app:strokeWidth="0dp" />
    </LinearLayout>

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/spacing_lg"
            android:paddingTop="@dimen/spacing_md"
            android:paddingBottom="@dimen/spacing_xl">

            <!-- ==== CGPA Card ==== -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardHero"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:shapeAppearance="@style/ShapeAppearance.Semora.HeroCard"
                app:cardBackgroundColor="@color/md3_primary"
                app:strokeWidth="0dp">

                <View
                    android:id="@+id/cgpaBackgroundOverlay"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="24dp">

                    <!-- CGPA value -->
                    <TextView
                        android:id="@+id/tvCgpaValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/TextAppearance.Semora.DisplayLarge"
                        android:textColor="@android:color/white"
                        android:text="0.00"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <!-- Semester & Credits -->
                    <TextView
                        android:id="@+id/tvSemesterLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/TextAppearance.Semora.BodySmall"
                        android:textColor="@android:color/white"
                        android:text="Semester 1"
                        app:layout_constraintStart_toStartOf="@id/tvCgpaValue"
                        app:layout_constraintTop_toBottomOf="@id/tvCgpaValue" />
                    <TextView
                        android:id="@+id/tvCreditsLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/TextAppearance.Semora.BodySmall"
                        android:textColor="@android:color/white"
                        android:text="0 Credits"
                        app:layout_constraintStart_toEndOf="@id/tvSemesterLabel"
                        app:layout_constraintTop_toTopOf="@id/tvSemesterLabel"
                        android:layout_marginStart="8dp" />

                    <!-- Percentage -->
                    <TextView
                        android:id="@+id/tvPercentage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/TextAppearance.Semora.BodySmall"
                        android:textColor="@android:color/white"
                        android:text="≈ 0 %"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBaseline_toBaselineOf="@id/tvCgpaValue" />

                    <!-- Progress Ring (custom view) -->
                    <com.prakash.semora.ui.home.CustomProgressRing
                        android:id="@+id/progressRing"
                        android:layout_width="96dp"
                        android:layout_height="96dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintVertical_bias="0.5" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ==== Dashboard Grid ==== -->
            <androidx.gridlayout.widget.GridLayout
                android:id="@+id/dashboardGrid"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:rowCount="3"
                android:columnCount="2"
                android:alignmentMode="alignBounds"
                android:columnOrderPreserved="false"
                android:paddingTop="16dp">

                <!-- Recent Semester -->
                <include
                    layout="@layout/item_dashboard_card"
                    android:id="@+id/cardRecentSemester"
                    android:layout_columnWeight="1"
                    android:layout_rowWeight="1"
                    android:layout_margin="8dp" />

                <!-- Total Subjects -->
                <include
                    layout="@layout/item_dashboard_card"
                    android:id="@+id/cardTotalSubjects"
                    android:layout_columnWeight="1"
                    android:layout_rowWeight="1"
                    android:layout_margin="8dp" />

                <!-- Credits Earned -->
                <include
                    layout="@layout/item_dashboard_card"
                    android:id="@+id/cardCreditsEarned"
                    android:layout_columnWeight="1"
                    android:layout_rowWeight="1"
                    android:layout_margin="8dp" />

                <!-- Overall Percentage -->
                <include
                    layout="@layout/item_dashboard_card"
                    android:id="@+id/cardOverallPercentage"
                    android:layout_columnWeight="1"
                    android:layout_rowWeight="1"
                    android:layout_margin="8dp" />

                <!-- Upcoming Exams -->
                <include
                    layout="@layout/item_dashboard_card"
                    android:id="@+id/cardUpcomingExams"
                    android:layout_columnWeight="1"
                    android:layout_rowWeight="1"
                    android:layout_margin="8dp" />

                <!-- Academic Insights -->
                <include
                    layout="@layout/item_dashboard_card"
                    android:id="@+id/cardAcademicInsights"
                    android:layout_columnWeight="1"
                    android:layout_rowWeight="1"
                    android:layout_margin="8dp" />

                <!-- Quick Actions -->
                <include
                    layout="@layout/item_dashboard_card"
                    android:id="@+id/cardQuickActions"
                    android:layout_columnWeight="1"
                    android:layout_rowWeight="1"
                    android:layout_margin="8dp" />

                <!-- Grade Distribution -->
                <include
                    layout="@layout/item_dashboard_card"
                    android:id="@+id/cardGradeDistribution"
                    android:layout_columnWeight="1"
                    android:layout_rowWeight="1"
                    android:layout_margin="8dp" />

                <!-- Recent Calculations -->
                <include
                    layout="@layout/item_dashboard_card"
                    android:id="@+id/cardRecentCalculations"
                    android:layout_columnWeight="1"
                    android:layout_rowWeight="1"
                    android:layout_margin="8dp" />
            </androidx.gridlayout.widget.GridLayout>

            <!-- Empty Offline State (cold start without network) -->
            <LinearLayout
                android:id="@+id/emptyOffline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">

                <ImageView
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:src="@drawable/ic_info"
                    android:importantForAccessibility="no"
                    app:tint="@color/md3_on_surface_variant" />

                <TextView
                    style="@style/TextAppearance.Semora.TitleMedium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:text="Connect to the internet to get started"
                    android:textColor="@color/md3_on_surface" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEmptyRetry"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:text="Retry"
                    style="@style/Widget.Material3.Button.OutlinedButton" />
            </LinearLayout>

            <!-- Empty State (shown when no grades exist) -->
            <LinearLayout
                android:id="@+id/emptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">

                <ImageView
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:src="@drawable/ic_empty_home"
                    android:importantForAccessibility="no" />

                <TextView
                    style="@style/TextAppearance.Semora.TitleMedium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:text="@string/empty_home_title"
                    android:textColor="@color/md3_on_surface" />

                <TextView
                    style="@style/TextAppearance.Semora.BodySmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:gravity="center"
                    android:text="@string/empty_home_subtitle"
                    android:textColor="@color/md3_on_surface_variant" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>


</androidx.constraintlayout.widget.ConstraintLayout>