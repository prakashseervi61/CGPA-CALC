<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md3_background">

    <!-- Top Bar -->
    <RelativeLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/md3_background"
        android:clipToPadding="false"
        android:paddingHorizontal="@dimen/spacing_lg"
        android:paddingTop="@dimen/spacing_md"
        android:paddingBottom="@dimen/spacing_xs"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvGreeting"
                style="@style/TextAppearance.Semora.Headline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="Good morning" />

            <TextView
                android:id="@+id/tvUsername"
                style="@style/TextAppearance.Semora.BodySmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="-2dp"
                android:textColor="@color/md3_on_surface_variant"
                tools:text="Alex" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnNotifications"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_notification_button"
            android:contentDescription="Notifications"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_notification" />
    </RelativeLayout>

    <!-- Error Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/errorCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:cardBackgroundColor="@color/md3_error_container"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        app:contentPadding="12dp"
        android:layout_margin="8dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_error"
                android:importantForAccessibility="no"
                app:tint="@color/md3_error" />

            <TextView
                android:id="@+id/errorText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="8dp"
                android:textAppearance="?attr/textAppearanceBodySmall" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/retryButton"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Retry" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Loading skeleton (shown while data loads) -->
    <LinearLayout
        android:id="@+id/loadingShimmer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/spacing_lg"
        android:paddingTop="@dimen/spacing_md"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="140dp"
            app:cardCornerRadius="@dimen/corner_large"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/md3_surface"
            app:strokeWidth="0dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:orientation="horizontal"
            android:weightSum="2">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/spacing_xxs"
                app:cardCornerRadius="@dimen/corner_medium"
                app:cardElevation="1dp"
                app:cardBackgroundColor="@color/md3_surface"
                app:strokeWidth="0dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/spacing_xxs"
                app:cardCornerRadius="@dimen/corner_medium"
                app:cardElevation="1dp"
                app:cardBackgroundColor="@color/md3_surface"
                app:strokeWidth="0dp" />
        </LinearLayout>

        <!-- Section title skeleton -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="120dp"
            android:layout_height="16dp"
            android:layout_marginTop="@dimen/spacing_lg"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/md3_surface"
            app:strokeWidth="0dp" />
    </LinearLayout>

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/spacing_lg"
            android:paddingTop="@dimen/spacing_md"
            android:paddingBottom="@dimen/spacing_xl">

            <!-- Hero CGPA Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardHero"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/corner_large"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/md3_surface"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="@dimen/spacing_lg"
                    android:weightSum="2">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.1"
                        android:orientation="vertical"
                        android:gravity="center_vertical">

                        <TextView
                            style="@style/TextAppearance.Semora.LabelSmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="OVERALL CGPA"
                            android:textColor="@color/md3_on_surface_variant" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xxs"
                            android:baselineAligned="true"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tvCgpa"
                                style="@style/TextAppearance.Semora.Metric"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/md3_primary"
                                tools:text="0.00" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/spacing_xxs"
                                android:layout_marginBottom="4dp"
                                android:alpha="0.6"
                                android:text="/ 10.0"
                                android:textColor="@color/md3_on_surface_variant"
                                android:textSize="18sp"
                                android:fontFamily="@font/inter_medium" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvCgpaMessage"
                            style="@style/TextAppearance.Semora.Caption"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textColor="@color/md3_on_surface_variant"
                            tools:text="Outstanding" />
                    </LinearLayout>

                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_weight="0.9"
                        android:gravity="end">

                        <com.google.android.material.progressindicator.CircularProgressIndicator
                            android:id="@+id/cgpaProgress"
                            android:layout_width="120dp"
                            android:layout_height="120dp"
                            android:layout_gravity="center"
                            app:indicatorColor="@color/md3_primary"
                            app:indicatorSize="120dp"
                            app:trackColor="@color/md3_primary_track"
                            app:trackThickness="14dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                style="@style/TextAppearance.Semora.LabelSmall"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Progress"
                                android:textColor="@color/md3_on_surface_variant" />

                            <TextView
                                android:id="@+id/tvProgressPercentage"
                                style="@style/TextAppearance.Semora.TitleSmall"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/md3_on_surface"
                                tools:text="0%" />
                        </LinearLayout>
                    </FrameLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Section: Statistics -->
            <TextView
                style="@style/TextAppearance.Semora.TitleSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:text="Statistics"
                android:textColor="@color/md3_on_surface" />

            <!-- Statistics: Two-column layout -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:orientation="horizontal"
                android:weightSum="2">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardSemesters"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/spacing_xxs"
                    app:cardCornerRadius="@dimen/corner_medium"
                    app:cardElevation="1dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_sm">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_school"
                            android:importantForAccessibility="no" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:baselineAligned="true"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tvSemesterCount"
                                style="@style/TextAppearance.Semora.MetricSmall"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/md3_on_surface"
                                android:includeFontPadding="false"
                                tools:text="0" />

                            <TextView
                                android:id="@+id/tvTotalSemesters"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="2dp"
                                android:layout_marginBottom="2dp"
                                android:text="/ 8"
                                android:textColor="@color/md3_on_surface_variant"
                                android:textSize="12sp"
                                android:fontFamily="@font/inter_regular" />
                        </LinearLayout>

                        <TextView
                            style="@style/TextAppearance.Semora.Caption"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Semesters"
                            android:textColor="@color/md3_on_surface_variant" />

                            <ProgressBar
                                android:id="@+id/semesterProgressBar"
                                style="@style/Widget.Material3.LinearProgressIndicator"
                                android:layout_width="match_parent"
                                android:layout_height="4dp"
                                android:layout_marginTop="@dimen/spacing_sm"
                                app:indicatorColor="@color/md3_primary"
                                app:trackColor="@color/md3_primary_track" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCredits"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/spacing_xxs"
                    app:cardCornerRadius="@dimen/corner_medium"
                    app:cardElevation="1dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_sm">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_credits"
                            android:importantForAccessibility="no" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:baselineAligned="true"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tvCreditsEarned"
                                style="@style/TextAppearance.Semora.MetricSmall"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/md3_on_surface"
                                android:includeFontPadding="false"
                                tools:text="0" />

                            <TextView
                                android:id="@+id/tvTotalCredits"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="2dp"
                                android:layout_marginBottom="2dp"
                                android:text="/ 180"
                                android:textColor="@color/md3_on_surface_variant"
                                android:textSize="12sp"
                                android:fontFamily="@font/inter_regular" />
                        </LinearLayout>

                        <TextView
                            style="@style/TextAppearance.Semora.Caption"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Credits"
                            android:textColor="@color/md3_on_surface_variant" />

                        <ProgressBar
                            android:id="@+id/creditsProgressBar"
                            style="@style/Widget.Material3.LinearProgressIndicator"
                            android:layout_width="match_parent"
                            android:layout_height="4dp"
                            android:layout_marginTop="@dimen/spacing_sm"
                            app:indicatorColor="@color/md3_primary"
                            app:trackColor="@color/md3_primary_track" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- Empty Offline State (cold start without network) -->
            <LinearLayout
                android:id="@+id/emptyOffline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">

                <ImageView
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:src="@drawable/ic_info"
                    android:importantForAccessibility="no"
                    app:tint="@color/md3_on_surface_variant" />

                <TextView
                    style="@style/TextAppearance.Semora.TitleMedium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:text="Connect to the internet to get started"
                    android:textColor="@color/md3_on_surface" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEmptyRetry"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:text="Retry"
                    style="@style/Widget.Material3.Button.OutlinedButton" />
            </LinearLayout>

            <!-- Empty State (shown when no grades exist) -->
            <LinearLayout
                android:id="@+id/emptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">

                <ImageView
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:src="@drawable/ic_empty_home"
                    android:importantForAccessibility="no" />

                <TextView
                    style="@style/TextAppearance.Semora.TitleMedium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:text="@string/empty_home_title"
                    android:textColor="@color/md3_on_surface" />

                <TextView
                    style="@style/TextAppearance.Semora.BodySmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:gravity="center"
                    android:text="@string/empty_home_subtitle"
                    android:textColor="@color/md3_on_surface_variant" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
