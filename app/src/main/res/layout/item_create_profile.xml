<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.Semora.ProfileCard"
    android:layout_width="match_parent"
    android:layout_height="180dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:strokeColor="@color/md3_outline_variant"
    app:strokeWidth="1dp"
    app:cardBackgroundColor="@color/pp_card_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/ivPlusIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_add"
            android:tint="@color/pp_primary"
            android:importantForAccessibility="no" />

        <TextView
            android:id="@+id/tvCreateProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="@string/pp_create_new"
            android:textColor="@color/pp_primary"
            android:textAppearance="@style/TextAppearance.Semora.PoppinsSemiBold" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
